# --- Database ---
DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/CreviaTube_Db

# --- Sessions ---
SESSION_SECRET=change-me-to-a-long-random-string

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Web3 (Phase 2) ---
# Reown AppKit project ID (from https://cloud.reown.com)
# Used in the client bundle, prefixed with VITE_
VITE_REOWN_PROJECT_ID=

# Alchemy Base RPC. Get from https://dashboard.alchemy.com.
# Use base-mainnet for prod, base-sepolia for dev.
ALCHEMY_BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# EVM chain id the app is configured for. 8453 = Base mainnet, 84532 = Base Sepolia.
WEB3_CHAIN_ID=84532

# USDC contract on the active chain.
# Base mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Where USDC deposits land. Public address only (this wallet should be watch-only).
PAYMENT_RECEIVE_WALLET=

# Private key of the *separate* hot wallet used to sign outbound clipper payouts.
# Funded with operating balance only. Rotate regularly. NEVER reuse the receive wallet's key.
PAYOUT_PRIVATE_KEY=

# --- NexaPay (card on-ramp; settles to PAYMENT_RECEIVE_WALLET as USDC) ---
NEXAPAY_API_KEY=
NEXAPAY_WEBHOOK_SECRET=

# --- Email (Resend) ---
# Get an API key from https://resend.com. If unset, emails are logged but not sent
# (useful for dev / running tests without a provider).
RESEND_API_KEY=

# Sender. Use "onboarding@resend.dev" for testing without DNS, or a verified
# domain like "CreviaTube <noreply@mail.creviatube.com>" for production.
EMAIL_FROM_ADDRESS=CreviaTube <onboarding@resend.dev>

# Public URL the app is served from. Used to build verification + reset links
# in transactional emails. http://localhost:5000 for dev.
APP_URL=http://localhost:5000
