# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/creocash

# Authentication
SESSION_SECRET=your-32-character-random-session-secret-here

# PesaPal Payment Configuration (for African payments)
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_BASE_URL=https://pay.pesapal.com/v3

# M-Pesa Payouts (Safaricom Daraja API)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=your-business-shortcode
MPESA_PASSKEY=your-passkey
MPESA_INITIATOR_NAME=your-initiator-name
MPESA_SECURITY_CREDENTIAL=your-security-credential
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# PayPal Payouts Configuration
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_BASE_URL=https://api.sandbox.paypal.com

# Note: Stripe not available in Kenya - using alternative payment methods

# Wise API (International Bank Transfers)
WISE_API_TOKEN=your-wise-api-token
WISE_PROFILE_ID=your-wise-profile-id
WISE_BASE_URL=https://api.sandbox.transferwise.tech

# Rapyd API (Global Banking & Cards)
RAPYD_ACCESS_KEY=your-rapyd-access-key
RAPYD_SECRET_KEY=your-rapyd-secret-key
RAPYD_BASE_URL=https://sandboxapi.rapyd.net

# Application URLs
FRONTEND_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000

# Environment
NODE_ENV=development

# Optional: Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password

# Optional: Social Media API Keys (for automatic metrics)
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
YOUTUBE_API_KEY=your-youtube-api-key
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret